# ───────────────── CrimeGPT Backend Environment Variables ─────────────────

# Application
APP_NAME=CrimeGPT
APP_VERSION=0.1.0
DEBUG=true
API_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Database (PostgreSQL + asyncpg)
DATABASE_URL=postgresql+asyncpg://crimegpt:crimegpt_pass@localhost:5432/crimegpt_db
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_ECHO=false

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_SESSION_TTL=28800

# Auth (JWT)
JWT_SECRET=change-me-to-a-real-secret-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=8
REFRESH_TOKEN_EXPIRY_DAYS=7

# LLM (cloud = Groq, local = Ollama)
LLM_MODE=cloud
GROQ_API_KEY=

# Multi-model routing — each task type uses the optimal model
GROQ_MODEL_PRIMARY=meta-llama/llama-4-scout-17b-16e-instruct  # FIR drafting, legal Q&A
GROQ_MODEL_FAST=llama-3.1-8b-instant                          # NER, classification
GROQ_MODEL_FALLBACK=llama-3.3-70b-versatile                   # Complex legal reasoning
GROQ_MODEL_WHISPER=whisper-large-v3-turbo                      # Speech-to-text

OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=mistral:7b-instruct

# ChromaDB (vector store for RAG)
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION=legal_corpus

# RAG ingestion (multi-source)
# Comma-separated domains (e.g., indiacode.nic.in,legislative.gov.in). Empty = allow all.
RAG_ALLOWED_DOMAINS=[]
RAG_ALLOW_HTTP_URLS=false
RAG_MAX_URL_BYTES=2000000
RAG_REQUEST_TIMEOUT_SECONDS=12
RAG_MAX_CONCURRENCY=4
RAG_MIN_TEXT_LENGTH=400
RAG_USER_AGENT=CrimeGPT-RAG-Ingest/1.0 (+https://github.com/XploitMonk0x01/crimegpt)
RAG_STRIP_PROMPT_INJECTION=true
RAG_REDACT_PII=false

# Sentry (optional)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=1.0
SENTRY_ENVIRONMENT=development

# Evidence Storage
EVIDENCE_STORAGE_PATH=./storage/evidence
EVIDENCE_MAX_FILE_SIZE_MB=50
